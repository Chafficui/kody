# Stage 1: Build
FROM node:22-alpine AS build

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace config
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./

# Copy package.json files for needed packages
COPY packages/shared/package.json packages/shared/
COPY packages/web/package.json packages/web/

# Install all dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY packages/shared/ packages/shared/
COPY packages/web/ packages/web/

# Build shared first, then web
RUN pnpm --filter @kody/shared run build && \
    pnpm --filter @kody/web run build

# Ensure public dir exists for the COPY in the next stage
RUN mkdir -p /app/packages/web/public

# Stage 2: Production runtime
FROM node:22-alpine AS runtime

WORKDIR /app

# Copy standalone output (includes node_modules and server.js)
COPY --from=build /app/packages/web/.next/standalone/ ./

# Copy static assets
COPY --from=build /app/packages/web/.next/static/ packages/web/.next/static/

# Copy public folder (Next.js standalone doesn't include it)
COPY --from=build /app/packages/web/public/ packages/web/public/

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

EXPOSE 3000

USER node

CMD ["node", "packages/web/.next/standalone/packages/web/server.js"]
