{
  "name": "kody",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @kody/server run dev",
    "dev:widget": "pnpm --filter @kody/widget run dev",
    "dev:web": "pnpm --filter @kody/web run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
